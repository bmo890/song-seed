{
  "expo": {
    "name": "SongNook",
    "slug": "songnook",
    "version": "1.0.0",
    "scheme": "songnook",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "extra": {
      "supportsRTL": true
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDFBF7"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "SongNook needs microphone access so you can record song ideas and voice memos.",
        "ITSAppUsesNonExemptEncryption": false,
        "UTExportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "com.bmostudio.songnook.archive",
            "UTTypeDescription": "SongNook Archive",
            "UTTypeConformsTo": [
              "com.pkware.zip-archive",
              "public.data"
            ],
            "UTTypeTagSpecification": {
              "public.filename-extension": [
                "songnook"
              ],
              "public.mime-type": [
                "application/zip"
              ]
            }
          }
        ],
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "SongNook Archive",
            "LSHandlerRank": "Owner",
            "LSItemContentTypes": [
              "com.bmostudio.songnook.archive"
            ]
          }
        ]
      },
      "bundleIdentifier": "com.bmostudio.songnook",
      "associatedDomains": ["applinks:send.songnook.app"]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FDFBF7"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "send.songnook.app", "pathPrefix": "/t/" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_PROMOTED_NOTIFICATIONS"
      ],
      "package": "com.bmostudio.songnook"
    },
    "plugins": [
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": ["en", "he"],
            "android": ["en", "he"]
          }
        }
      ],
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsFileWithMaxCount": 20
          },
          "androidIntentFilters": [
            "audio/*",
            "application/zip",
            "application/x-zip-compressed",
            "application/octet-stream"
          ],
          "androidMultiIntentFilters": [
            "audio/*"
          ],
          "iosShareExtensionName": "SongNook Import"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "SongNook needs microphone access so you can record song ideas and voice memos.",
          "enableBackgroundRecording": true
        }
      ],
      [
        "@siteed/audio-studio",
        {
          "microphonePermission": "SongNook needs microphone access so you can record song ideas and voice memos.",
          "enableBackgroundAudio": true,
          "enableNotifications": true,
          "enableDeviceDetection": true,
          "iosBackgroundModes": {
            "useAudio": true,
            "useProcessing": true
          },
          "iosConfig": {
            "microphoneUsageDescription": "SongNook needs microphone access so you can record song ideas and voice memos.",
            "notificationUsageDescription": "SongNook uses recording notifications so background recording can continue.",
            "allowBackgroundAudioControls": true
          }
        }
      ],
      "./plugins/withSongNookAndroidVariants",
      "expo-font",
      "expo-sqlite"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
